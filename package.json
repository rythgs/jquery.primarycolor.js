{
  "name": "jquery.primarycolor.js",
  "version": "3.0.0",
  "description": "Detect the primary color of an image with a modern API and jQuery plugin adapter.",
  "keywords": [
    "color",
    "jquery",
    "plugin"
  ],
  "homepage": "https://github.com/rythgs/jquery.primarycolor.js#readme",
  "bugs": {
    "url": "https://github.com/rythgs/jquery.primarycolor.js/issues"
  },
  "license": "MIT",
  "author": "rythgs",
  "repository": {
    "type": "git",
    "url": "https://github.com/rythgs/jquery.primarycolor.js.git"
  },
  "source": "src/index.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/jquery.js",
    "./dist/jquery.cjs",
    "./dist/jquery.primarycolor.umd.js"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jquery": {
      "types": "./dist/jquery.d.ts",
      "import": "./dist/jquery.js",
      "require": "./dist/jquery.cjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun run bundle",
    "ci": "bun run lint && bun run test && bun run build && bun run test:dist",
    "compile": "tsc",
    "bundle": "bun run bundle:modules && bun run bundle:umd",
    "bundle:modules": "tsup",
    "bundle:umd": "rollup -c",
    "fix": "oxlint --fix && oxfmt",
    "lint": "oxlint && oxfmt --check && tsc --noEmit",
    "lint:type": "tsc --noEmit",
    "test": "vitest run --exclude \"test/**/*.test.ts\"",
    "test:dist": "vitest run test/*.test.ts",
    "test:umd": "vitest run test/umd.test.ts",
    "prepare": "bun run build"
  },
  "devDependencies": {
    "@types/jquery": "4.0.0",
    "@types/node": "24.12.4",
    "jquery": "4.0.0",
    "jsdom": "29.1.1",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "rollup": "4.60.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "jquery": ">=4 <5"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14"
}
