{
  "name": "jquery.primarycolor.js",
  "version": "2.0.0",
  "description": "Detect the primary color of an image with a modern API and jQuery plugin adapter.",
  "keywords": [
    "jquery",
    "plugin",
    "color"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rythgs/jquery.primarycolor.js.git"
  },
  "homepage": "https://github.com/rythgs/jquery.primarycolor.js#readme",
  "bugs": {
    "url": "https://github.com/rythgs/jquery.primarycolor.js/issues"
  },
  "author": "rythgs",
  "license": "MIT",
  "source": "src/index.ts",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jquery": {
      "types": "./dist/jquery.d.ts",
      "import": "./dist/jquery.js",
      "require": "./dist/jquery.cjs"
    }
  },
  "sideEffects": [
    "./dist/jquery.js",
    "./dist/jquery.cjs",
    "./dist/jquery.primarycolor.umd.js"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "run-s clean bundle",
    "ci": "run-s lint test build test:dist",
    "compile": "tsc",
    "bundle": "run-s bundle:modules bundle:umd",
    "bundle:modules": "tsup",
    "bundle:umd": "rollup -c",
    "fix": "run-p fix:*",
    "fix:eslint": "npm run lint:eslint -- --fix",
    "fix:prettier": "npm run lint:prettier -- --write",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint --ext js,ts .",
    "lint:prettier": "prettier -l .",
    "lint:type": "tsc --noEmit",
    "test": "vitest run --exclude \"test/**/*.test.ts\"",
    "test:dist": "vitest run test/*.test.ts",
    "test:umd": "vitest run test/umd.test.ts",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/jquery": "3.5.30",
    "@typescript-eslint/eslint-plugin": "7.17.0",
    "@typescript-eslint/parser": "7.17.0",
    "eslint": "8.56.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-plugin-import": "2.29.1",
    "jquery": "3.7.1",
    "jsdom": "24.1.3",
    "npm-run-all": "4.1.5",
    "prettier": "3.3.3",
    "rimraf": "^6.0.1",
    "rollup": "4.18.1",
    "tsup": "8.3.5",
    "typescript": "^5.5.4",
    "vitest": "2.0.5"
  },
  "peerDependencies": {
    "jquery": ">=3.7 <4"
  },
  "engines": {
    "node": ">= 18",
    "npm": ">= 9.5"
  },
  "files": [
    "dist"
  ]
}
